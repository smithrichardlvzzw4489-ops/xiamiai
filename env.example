# PostgreSQL。Supabase 建议两条（Dashboard → Connect → ORM / App Frameworks）：
# - DATABASE_URL：Transaction pooler（6543）+ ?pgbouncer=true（给 Prisma 运行时）
# - DIRECT_URL：Direct connection（主机多为 db.<project-ref>.supabase.co:5432，给 migrate）
# 勿把 DIRECT 写成 pooler 的 5432；密码含特殊字符需 URL 编码。建议两串末尾都加 &sslmode=require
# Vercel 构建常连不上 Supabase 直连(5432)。迁移请在本地执行：npm run db:migrate（需同上两条 env）
DATABASE_URL=""
DIRECT_URL=""
JWT_SECRET="replace-with-long-random-string"
OPENROUTER_API_KEY=""
# 可选：默认 https://openrouter.ai/api/v1 与 openai/gpt-5.4-image-2
# OPENROUTER_BASE_URL=""
# OPENROUTER_IMAGE_MODEL=""
# OPENROUTER_HTTP_REFERER="https://你的站点"
# OPENROUTER_APP_TITLE="虾米AI"
