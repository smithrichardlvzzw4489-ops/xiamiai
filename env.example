# PostgreSQL。Supabase 建议两条（Dashboard → Connect → ORM / App Frameworks）：
# - DATABASE_URL：Transaction pooler（6543）+ ?pgbouncer=true（给 Prisma 运行时）
# - DIRECT_URL：Direct connection（主机多为 db.<project-ref>.supabase.co:5432，给 migrate）
# 勿把 DIRECT 写成 pooler 的 5432；密码含特殊字符需 URL 编码。建议两串末尾都加 &sslmode=require
# Vercel 构建常连不上 Supabase 直连(5432)。迁移请在本地执行：npm run db:migrate（需同上两条 env）
DATABASE_URL=""
DIRECT_URL=""
JWT_SECRET="replace-with-long-random-string"
APP_SECRET="replace-with-different-long-random-string"
OPENROUTER_API_KEY=""

# 发信（二选一或都配，优先 Resend）
# Resend：https://resend.com 注册后创建 API Key；发件人需为已验证域名，测试可用 onboarding@resend.dev
RESEND_API_KEY=""
RESEND_FROM="隙光 <onboarding@resend.dev>"

# 或 SMTP（QQ 邮箱示例：SMTP_HOST=smtp.qq.com  SMTP_PORT=465  SMTP_SECURE=true
# SMTP_USER=你的QQ号@qq.com  SMTP_PASS=QQ邮箱「授权码」非登录密码）
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
